      "schema": {
        "version": 8,
        "hash": "8b21d2a1"
      },
      "mutations": [
        {
          "mutation_id": "m_001",
          "table": "workouts",
          "op": "insert",
          "pk": {
            "id": "w_1"
          },
          "columns": {
            "user_id": "u_123",
