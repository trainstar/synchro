{
  "fixture_version": 1,
  "name": "push_mixed_accept_and_conflict_reject",
  "kind": "protocol.push",
  "summary": "A push batch may accept some mutations and reject others with authoritative server state.",
  "spec_refs": [
    "01-wire-protocol: Mutation Model",
