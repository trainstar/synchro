            "started_at": "2026-03-20T18:00:00Z"
          }
        },
        {
          "mutation_id": "m_003",
          "table": "workouts",
          "op": "delete",
          "pk": {
            "id": "w_3"
          },
          "base_version": "sv_777"
        }
      ]
    }
  },
  "expected": {
    "response": {
      "server_time": "2026-03-20T18:22:11Z",
