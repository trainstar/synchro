{
  "name": "@trainstar/synchro-react-native",
  "version": "0.2.0",
  "description": "React Native bridge for Synchro sync SDK",
  "source": "./src/index.ts",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "*.podspec",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace @trainstar/synchro-react-native-example",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "prepare": "bob build",
    "pack:dry-run": "npm pack --dry-run",
    "test:unit": "jest --runInBand",
    "typecheck": "tsc",
    "lint": "eslint src/ __tests__/",
    "test": "jest"
  },
  "keywords": [
    "react-native",
    "synchro",
    "sync",
    "offline-first"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trainstar/synchro.git"
  },
  "author": "Trainstar <dev@trainstar.com> (https://trainstar.com)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/trainstar/synchro/issues"
  },
  "homepage": "https://github.com/trainstar/synchro#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@react-native/babel-preset": "0.83.0",
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "del-cli": "^6.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "react": "19.2.0",
    "react-native": "0.83.0",
    "react-native-builder-bob": "^0.40.18",
    "react-test-renderer": "^19.2.0",
    "ts-jest": "^29.1.0",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "SynchroModuleSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.trainstar.synchro.rn"
    },
    "ios": {
      "modulesProvider": {
        "SynchroModule": "SynchroModule"
      }
    }
  },
  "jest": {
    "preset": "react-native",
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "moduleNameMapper": {
      "^react-native$": "<rootDir>/__tests__/__mocks__/react-native"
    },
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/example/e2e",
      "<rootDir>/node_modules",
      "<rootDir>/__tests__/__mocks__"
    ]
  },
  "create-react-native-library": {
    "type": "turbo-module",
    "languages": "kotlin-objc",
    "tools": [
      "jest"
    ],
    "version": "0.57.2"
  }
}
